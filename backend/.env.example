# CVE Database API - Environment Variables
# Copy this file to .env and fill in with your values

# Application Settings
DEBUG=False
APP_NAME=CVE Database API
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cve_db

# JWT & Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
FRONTEND_URL=http://localhost:3000

# NVD API
NVD_API_KEY=your-nvd-api-key-from-https-services-nvd-nist-gov

# Exploit-DB API (optional)
EXPLOIT_DB_API_KEY=your-exploit-db-api-key

# Encryption
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Rate Limiting
RATE_LIMIT_PER_HOUR=100
RATE_LIMIT_GLOBAL_PER_HOUR=1000

# Sync Intervals (minutes)
FULL_SYNC_INTERVAL=60
DELTA_SYNC_INTERVAL=10
